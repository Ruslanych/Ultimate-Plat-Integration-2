{
	"geode": "5.4.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "ruslanych.ultimate-plat-integration-2",
	"name": "Ultimate Plat Integration",
	"version": "v1.0.4",
	"developer": "Ruslanych",
	"description": "Every Platformer List + Difficulty Chart",
	"dependencies": {
		"geode.node-ids": ">=v1.23.3"
	},
	"links": {
		"source": "https://github.com/Ruslanych/Ultimate-Plat-Integration-2"
	},
	"tags": [
		"api",
		"enhancement",
		"interface",
		"online"
	],
	"settings": {
		"enable-mod": {
			"name": "Enable mod",
			"type": "bool",
			"default": true
		},
		"enable-levelcell": {
			"name": "Show in levels tab",
			"type": "bool",
			"default": true,
			"enable-if": "enable-mod"
		},
		"enable-levelinfolayer": {
			"name": "Show on level page",
			"type": "bool",
			"default": true,
			"enable-if": "enable-mod"
		},
		"hide-aredl": {
			"name": "Hide \"Integrated Demonlist\" label",
			"description": "Hides \"Integrated Demonlist\" mod's label for platformers (kinda)",
			"type": "bool",
			"default": true,
			"enable-if": "enable-mod"
		},
		"hide-global-list": {
			"name": "Hide \"Global List Integrated\" label",
			"description": "Hides \"Global List Integrated\" mod's label for platformers",
			"type": "bool",
			"default": true,
			"enable-if": "enable-mod"
		},
		"compact-mode": {
			"name": "Compact labels mode",
			"description": "Configures the compatibility with other mods",
			"type": "string",
			"one-of": ["Standard", "SendDB compact"],
			"default": "Standard",
			"enable-if": "enable-mod"
		}
	},
	"resources": {
        "sprites": [
            "resources/tpl.png",
            "resources/pemon.png",
            "resources/update_btn.png",
			"resources/tiers/*"
        ]
    }
}
